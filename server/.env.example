# انسخ هذا الملف إلى .env وضع مفاتيحك من لوحة LiveKit Cloud
# (Settings ➜ Keys). لا ترفع .env إلى Git أبداً.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_api_key
LIVEKIT_API_SECRET=your_api_secret

# كلمة سر مالك اللعبة — من يدخلها يصبح المالك الرسمي (رصيد لانهائي + ملكية غرفة 000000).
# اجعلها قوية وسرّية. إن تُركت فارغة يُعطَّل دخول المالك تماماً.
OWNER_KEY=ضع_رمزاً_سرياً_قوياً_هنا
