{
  "appId": "com.voiceroom.app",
  "appName": "الغرفة الصوتية",
  "webDir": "dist",
  "backgroundColor": "#2a1f33",
  "android": {
    "allowMixedContent": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1200,
      "backgroundColor": "#2a1f33",
      "showSpinner": false,
      "androidScaleType": "CENTER_CROP"
    },
    "Keyboard": {
      "resize": "body"
    }
  }
}
